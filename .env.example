# Bevo Agent credentials (from Bevo developer portal)
BEVO_API_KEY=bevo_apikey_...
BEVO_API_BASE=https://bevo-server-staging.up.railway.app

# Agent's own Polygon EOA wallet (holds pooled USDC for bets)
AGENT_PRIVATE_KEY=0x...

# Polygon RPC
POLYGON_RPC_URL=https://polygon-rpc.com

# Public URL where this service is deployed (for miniapp links in cards)
MINIAPP_URL=https://your-app.railway.app

# Port
PORT=3000
